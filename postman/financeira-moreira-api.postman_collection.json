{
  "info": {
    "name": "Financeira Moreira API",
    "description": "Collection completa — Financeira Moreira Backend\n\n**Perfil dev:** usa header `X-Dev-User-Id` no lugar de Firebase JWT.\n**Perfil prod:** use `Authorization: Bearer <firebase-token>`.\n\nVariáveis de ambiente:\n- `base_url` — URL do backend\n- `dev_user_id` — UID do usuário de teste\n- `category_id` — preenchido automaticamente após POST /categories",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://financeira-moreira-api.onrender.com",
      "description": "Trocar para http://localhost:8080 para testar local"
    },
    {
      "key": "dev_user_id",
      "value": "dev-user-001",
      "description": "UID injetado pelo DevAuthFilter em dev"
    },
    {
      "key": "category_id",
      "value": "",
      "description": "Preenchido automaticamente pelo POST /categories"
    }
  ],
  "item": [

    {
      "name": "🌐 Público",
      "item": [
        {
          "name": "GET /api/sync — health check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/sync",
            "description": "Endpoint público, sem autenticação. Retorna 'Sincronizado'."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Corpo contém Sincronizado', () => pm.expect(pm.response.text()).to.include('Sincronizado'));"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "📲 Notificações",
      "item": [
        {
          "name": "POST /api/notificacoes/teste",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/notificacoes/teste",
            "header": [
              { "key": "X-Dev-User-Id", "value": "{{dev_user_id}}" }
            ],
            "description": "Envia mensagem de teste via CallMeBot (assíncrono, timeout 20s)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Campo status presente', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/notificacoes/enviar — mensagem customizada",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/notificacoes/enviar",
            "header": [
              { "key": "X-Dev-User-Id", "value": "{{dev_user_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mensagem\": \"🧪 Teste manual via Postman — {{$isoTimestamp}}\"\n}"
            },
            "description": "Envia mensagem customizada para o WhatsApp via CallMeBot."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Mensagem no response', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.mensagem).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "🗂️ Categorias",
      "item": [

        {
          "name": "GET /api/categories — listar todas",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/categories",
            "header": [
              { "key": "X-Dev-User-Id", "value": "{{dev_user_id}}" }
            ],
            "description": "Lista todas as categorias do usuário autenticado."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Resposta é array', () => {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('Categoria tem campos obrigatórios', () => {",
                  "  const lista = pm.response.json();",
                  "  if (lista.length > 0) {",
                  "    const cat = lista[0];",
                  "    pm.expect(cat).to.have.all.keys('id','name','icon','budget','color','type','nature');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "POST /api/categories — criar",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/categories",
            "header": [
              { "key": "X-Dev-User-Id", "value": "{{dev_user_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pets\",\n  \"icon\": \"🐶\",\n  \"budget\": 200.00,\n  \"color\": \"#f59e0b\",\n  \"type\": \"expense\",\n  \"nature\": \"desejo\"\n}"
            },
            "description": "Cria nova categoria. Salva o ID retornado em `category_id` automaticamente."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('ID retornado', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('string');",
                  "  pm.collectionVariables.set('category_id', json.id);",
                  "  console.log('category_id salvo:', json.id);",
                  "});",
                  "pm.test('Nome correto', () => {",
                  "  pm.expect(pm.response.json().name).to.eql('Pets');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "POST /api/categories — 422 nome duplicado",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/categories",
            "header": [
              { "key": "X-Dev-User-Id", "value": "{{dev_user_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pets\",\n  \"icon\": \"🐶\",\n  \"budget\": 200.00,\n  \"color\": \"#f59e0b\",\n  \"type\": \"expense\",\n  \"nature\": \"desejo\"\n}"
            },
            "description": "Tenta criar categoria com nome já existente. Espera 422."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422 Unprocessable', () => pm.response.to.have.status(422));",
                  "pm.test('Mensagem de erro presente', () => {",
                  "  pm.expect(pm.response.json().message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "POST /api/categories — 400 validação",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/categories",
            "header": [
              { "key": "X-Dev-User-Id", "value": "{{dev_user_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"icon\": \"🐶\",\n  \"budget\": 200.00,\n  \"color\": \"#f59e0b\",\n  \"type\": \"tipo_invalido\",\n  \"nature\": \"desejo\"\n}"
            },
            "description": "name em branco + type inválido — espera 400 com mapa de erros."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('Erro no campo name', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('name');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "PUT /api/categories/:id — atualizar",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/categories/{{category_id}}",
            "header": [
              { "key": "X-Dev-User-Id", "value": "{{dev_user_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pets & Veterinário\",\n  \"icon\": \"🐾\",\n  \"budget\": 350.00,\n  \"color\": \"#10b981\",\n  \"type\": \"expense\",\n  \"nature\": \"essencial\"\n}"
            },
            "description": "Atualiza a categoria criada no passo anterior. Usa `category_id` salvo automaticamente."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Nome atualizado', () => {",
                  "  pm.expect(pm.response.json().name).to.eql('Pets & Veterinário');",
                  "});",
                  "pm.test('Budget atualizado', () => {",
                  "  pm.expect(pm.response.json().budget).to.eql(350.00);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "PUT /api/categories/:id — 404 não encontrado",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/categories/00000000-0000-0000-0000-000000000000",
            "header": [
              { "key": "X-Dev-User-Id", "value": "{{dev_user_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Inexistente\",\n  \"icon\": \"❓\",\n  \"budget\": 0,\n  \"color\": \"#000\",\n  \"type\": \"expense\",\n  \"nature\": null\n}"
            },
            "description": "UUID que não existe — espera 404."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));",
                  "pm.test('Campo message presente', () => {",
                  "  pm.expect(pm.response.json().message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "DELETE /api/categories/:id — deletar",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/categories/{{category_id}}",
            "header": [
              { "key": "X-Dev-User-Id", "value": "{{dev_user_id}}" }
            ],
            "description": "Remove a categoria. Espera 204 No Content."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204 No Content', () => pm.response.to.have.status(204));",
                  "pm.test('Body vazio', () => pm.expect(pm.response.text()).to.be.empty);",
                  "pm.collectionVariables.set('category_id', '');"
                ]
              }
            }
          ]
        },

        {
          "name": "DELETE /api/categories/:id — 404 não encontrado",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/categories/00000000-0000-0000-0000-000000000000",
            "header": [
              { "key": "X-Dev-User-Id", "value": "{{dev_user_id}}" }
            ],
            "description": "UUID inexistente — espera 404."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },

        {
          "name": "GET /api/categories — 4xx sem autenticação",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/categories",
            "description": "Sem header de autenticação — espera 401 ou 403."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 4xx', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ]
              }
            }
          ]
        }

      ]
    }
  ]
}
